# .env.example
# =============================================================
# ORBIT-I PULSE — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env.local and fill in real values:
#
#   cp .env.example .env.local
#
# NEVER commit .env.local to git, and never paste real secrets
# into this file either — it IS committed to git. After filling
# in .env.local, visit /api/health (e.g. http://localhost:3000/api/health)
# to confirm everything is wired up correctly before testing login/register.
# =============================================================

# ---------- PUBLIC (safe to expose to the browser) ----------
# Must be prefixed NEXT_PUBLIC_ or Next.js will not expose them
# client-side. These control WHITE-LABEL BRANDING only — they are
# NOT used for Supabase connection (see PRIVATE section below).

NEXT_PUBLIC_COMPANY_NAME="ORBIT-I PULSE"
NEXT_PUBLIC_LOGO_URL="/orbit-i-logo.jpg"
NEXT_PUBLIC_FAVICON_URL="/orbit-i-logo.jpg"
NEXT_PUBLIC_ADMIN_EMAIL="admin@example.com"
NEXT_PUBLIC_PRIMARY_COLOR="#0F766E"
NEXT_PUBLIC_SECONDARY_COLOR="#0C0A09"

# ---------- PRIVATE (server-only — NEVER prefix with NEXT_PUBLIC_) ----------
# These must NOT be exposed to the browser. Set them in Vercel under
# Project Settings -> Environment Variables, not in any client code,
# and never commit real values for these into this file.
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY come from your Supabase
# project: Project Settings -> API.
#   - SUPABASE_URL is the "Project URL" field.
#   - SUPABASE_SERVICE_ROLE_KEY is the "service_role" secret key —
#     NOT the "anon" / "public" key. Using the anon key here will
#     cause every database write to silently fail or be blocked.

SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="paste-your-real-service-role-key-into-.env.local-only"

# JWT_SECRET signs and verifies every login session. Without this,
# NO login or registration will work at all. Generate a real one
# with: openssl rand -base64 32
# Use a DIFFERENT secret for every client deployment.

JWT_SECRET="paste-a-freshly-generated-secret-into-.env.local-only"

# ---------- LICENSING (only needed if you're selling this as white-label) ----------
# Leave both of these BLANK for your own internal/unlicensed use — the
# app runs completely normally with no license configured. Only set
# these on a deployment you're selling to a client.
#
# LICENSE_PUBLIC_KEY: the SAME value on every deployment you ever sell.
#   Generate once with: node scripts/generate-license-keypair.mjs
#   Then paste the contents of license-keys/public.pem here.
#
# LICENSE_KEY: a UNIQUE value per client, generated with:
#   node scripts/generate-license.mjs "Client Company Name"
#   Give the printed key to that specific client only.

LICENSE_PUBLIC_KEY=""
LICENSE_KEY=""
